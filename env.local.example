# ============================================================================
# FINTRUST AGENT - Environment Configuration Template
# DO NOT commit .env.local to version control. This file is .gitignored.
# ============================================================================

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Database (via Supabase)
DATABASE_URL=postgresql://postgres:[password]@db.supabase.co:5432/postgres

# Google AI (Gemini API)
GOOGLE_AI_API_KEY=AIzaSyD...

# Pinecone Vector Database (for RAG)
PINECONE_API_KEY=pcsk_...
PINECONE_ENVIRONMENT=gcp-starter
PINECONE_INDEX=fintrust-bylaws

# Encryption Keys (keep secure!)
ENCRYPTION_KEY=your-32-byte-hex-encoded-key
ENCRYPTION_SALT=your-salt-value

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Feature Flags
NEXT_PUBLIC_ENABLE_AI_AGENT=true
NEXT_PUBLIC_ENABLE_RAG=true
NEXT_PUBLIC_ENABLE_PREDICTIONS=true

# Email/Notifications (optional - Resend, SendGrid, etc.)
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_...

# Logging & Monitoring
LOG_LEVEL=debug
SENTRY_DSN=https://...